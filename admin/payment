<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>CMFilings Payment QR Generator</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<!-- LUCIDE -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/lucide-static@latest/font/lucide.css">

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<style>

:root{
    --primary:#C70000;
    --primary-dark:#980000;
    --white:#ffffff;
    --light:#F4F4F4;
    --border:#E8E8E8;
    --text:#3A3A3A;
    --sub:#8C8C8C;
    --shadow:0 10px 30px rgba(0,0,0,0.06);
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Poppins',sans-serif;
    background:var(--light);
    color:var(--text);
    padding:24px;
}

.container{
    max-width:520px;
    margin:auto;
}

.card{
    background:var(--white);
    border-radius:34px;
    padding:28px;
    box-shadow:var(--shadow);
}

.brand{
    display:flex;
    flex-direction:column;
    align-items:center;
    margin-bottom:28px;
}

.brand img.logo{
    width:74px;
    margin-bottom:14px;
}

.brand img.name{
    width:220px;
    margin-bottom:8px;
}

.brand p{
    font-size:13px;
    color:var(--sub);
}

.title{
    font-size:26px;
    font-weight:700;
    margin-bottom:24px;
    text-align:center;
}

.input-wrap{
    position:relative;
    margin-bottom:18px;
}

.field-icon{
    position:absolute;
    left:18px;
    top:50%;
    transform:translateY(-50%);
    font-size:20px;
    color:#B5B5B5;
    transition:0.25s ease;
}

.input-wrap input,
.input-wrap textarea{
    width:100%;
    border:none;
    outline:none;
    background:#FAFAFA;
    border:1px solid var(--border);
    border-radius:20px;
    padding:18px 18px 18px 54px;
    font-size:14px;
    color:var(--text);
    font-family:'Poppins',sans-serif;
    transition:0.25s ease;
}

.input-wrap textarea{
    resize:none;
    height:100px;
}

.input-wrap input:focus,
.input-wrap textarea:focus{
    border-color:#DADADA;
    background:#fff;
}

.input-wrap input:focus + .field-icon,
.input-wrap textarea:focus + .field-icon{
    color:var(--primary);
}

.btn{
    width:100%;
    border:none;
    border-radius:20px;
    padding:18px;
    font-size:15px;
    font-weight:600;
    cursor:pointer;
    transition:0.25s ease;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:10px;
    margin-top:14px;
}

.btn-primary{
    background:linear-gradient(135deg,var(--primary),var(--primary-dark));
    color:white;
}

.btn-secondary{
    background:#EFEFEF;
    color:#555;
}

.btn:hover{
    transform:translateY(-2px);
}

.qr-section{
    margin-top:34px;
    display:none;
}

.qr-box{
    background:#fff;
    border-radius:28px;
    padding:24px;
    text-align:center;
    border:1px solid var(--border);
}

#qrcode{
    display:flex;
    justify-content:center;
    margin-bottom:18px;
}

.payment-details{
    margin-top:20px;
}

.payment-details h3{
    font-size:22px;
    margin-bottom:8px;
}

.payment-details p{
    color:var(--sub);
    line-height:1.8;
    font-size:14px;
}

.amount{
    font-size:34px;
    color:var(--primary);
    font-weight:700;
    margin-top:18px;
}

.bottom-nav{
    position:fixed;
    bottom:0;
    left:0;
    width:100%;
    background:white;
    border-top:1px solid #ECECEC;
    display:flex;
    justify-content:space-around;
    padding:12px 0 10px;
}

.nav-item{
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:6px;
    text-decoration:none;
    color:#A5A5A5;
    font-size:12px;
    font-weight:500;
}

.nav-item i{
    font-size:22px;
}

.nav-item.active{
    color:var(--primary);
}

@media(max-width:600px){

body{
    padding:18px;
}

.card{
    border-radius:28px;
    padding:22px;
}

.title{
    font-size:22px;
}

}

</style>

</head>

<body>

<div class="container">

    <div class="card">

        <!-- BRAND -->

        <div class="brand">

            <img
                src="logo-dark.png"
                class="logo"
            >

            <img
                src="Name-dark.png"
                class="name"
            >

            <p>
                Experts in Tax & Business Compliances
            </p>

        </div>

        <!-- TITLE -->

        <div class="title">
            Payment QR Generator
        </div>

        <!-- UPI -->

        <div class="input-wrap">

            <input
                type="text"
                id="upi"
                placeholder="CMFilings UPI ID"
                value="cmfilings@upi"
            >

            <i class="icon-wallet-minimal field-icon"></i>

        </div>

        <!-- CLIENT NAME -->

        <div class="input-wrap">

            <input
                type="text"
                id="clientName"
                placeholder="Client Name"
            >

            <i class="icon-user-round field-icon"></i>

        </div>

        <!-- MOBILE -->

        <div class="input-wrap">

            <input
                type="number"
                id="mobile"
                placeholder="Client Mobile Number"
            >

            <i class="icon-smartphone field-icon"></i>

        </div>

        <!-- DESCRIPTION -->

        <div class="input-wrap">

            <textarea
                id="description"
                placeholder="Payment Description"
            ></textarea>

            <i class="icon-file-text field-icon"></i>

        </div>

        <!-- AMOUNT -->

        <div class="input-wrap">

            <input
                type="number"
                id="amount"
                placeholder="Amount"
            >

            <i class="icon-badge-indian-rupee field-icon"></i>

        </div>

        <!-- BUTTONS -->

        <button
            class="btn btn-primary"
            onclick="generateQR()"
        >

            <i class="icon-scan-line"></i>
            Generate QR

        </button>

        <button
            class="btn btn-secondary"
            onclick="sendWhatsApp()"
        >

            <i class="icon-message-circle"></i>
            Send to WhatsApp

        </button>

        <!-- QR -->

        <div
            class="qr-section"
            id="qrSection"
        >

            <div class="qr-box">

                <div id="qrcode"></div>

                <div class="payment-details">

                    <h3 id="displayName"></h3>

                    <p id="displayDescription"></p>

                    <div class="amount" id="displayAmount"></div>

                </div>

            </div>

        </div>

    </div>

</div>

<!-- BOTTOM NAV -->

<nav class="bottom-nav">

    <a href="#" class="nav-item active">
        <i class="icon-house"></i>
        <span>Home</span>
    </a>

    <a href="#" class="nav-item">
        <i class="icon-briefcase-business"></i>
        <span>Services</span>
    </a>

    <a href="#" class="nav-item">
        <i class="icon-wrench"></i>
        <span>Tools</span>
    </a>

    <a href="#" class="nav-item">
        <i class="icon-chart-column"></i>
        <span>Reports</span>
    </a>

    <a href="#" class="nav-item">
        <i class="icon-circle-user-round"></i>
        <span>Account</span>
    </a>

</nav>

<script>

function generateQR(){

    const upi = document.getElementById('upi').value;
    const clientName = document.getElementById('clientName').value;
    const mobile = document.getElementById('mobile').value;
    const description = document.getElementById('description').value;
    const amount = document.getElementById('amount').value;

    if(!upi || !clientName || !amount){

        alert('Please fill required fields');
        return;

    }

    const paymentLink =
    `upi://pay?pa=${upi}&pn=CMFilings&am=${amount}&cu=INR&tn=${description}`;

    document.getElementById('qrcode').innerHTML = '';

    new QRCode(document.getElementById("qrcode"), {
        text: paymentLink,
        width:220,
        height:220
    });

    document.getElementById('displayName').innerText = clientName;
    document.getElementById('displayDescription').innerText = description;
    document.getElementById('displayAmount').innerText = '₹ ' + amount;

    document.getElementById('qrSection').style.display = 'block';

}

function sendWhatsApp(){

    const clientName =
    document.getElementById('clientName').value;

    const mobile =
    document.getElementById('mobile').value;

    const description =
    document.getElementById('description').value;

    const amount =
    document.getElementById('amount').value;

    const upi =
    document.getElementById('upi').value;

    if(!mobile){

        alert('Enter mobile number');
        return;

    }

    const paymentLink =
    `upi://pay?pa=${upi}&pn=CMFilings&am=${amount}&cu=INR&tn=${description}`;

    const message =
`*Payment Request From CMFilings*

Dear ${clientName}

Your Payment For (*${description}*) is Due.

Amount: (*Rs.${amount}*)

Pay now:
${paymentLink}`;

    const whatsappURL =
    `https://wa.me/91${mobile}?text=${encodeURIComponent(message)}`;

    window.open(whatsappURL,'_blank');

}

</script>

</body>
</html>